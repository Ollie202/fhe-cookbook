# Sepolia deployment config — copy this file to `.env` and fill in real values.
# DO NOT commit `.env` (it's gitignored).

# 1) RPC URL — free from https://www.alchemy.com or https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# 2) Deployer private key — burner wallet only. NEVER use a wallet with mainnet funds.
# Get Sepolia ETH from: https://sepoliafaucet.com or https://www.alchemy.com/faucets/ethereum-sepolia
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HEX

# 3) Etherscan API key (optional — for contract verification)
# Get free at: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY
